# Rawi Press Saudi Collector — secrets. Copy to .env and fill in.
# .env is gitignored. The device is Tailscale-only and trusted, so holding the
# service role key locally is acceptable — just never commit it.

# --- required: ingest endpoint auth ---
SUPABASE_URL=https://uiwblgqhpjhbtmlgnfkk.supabase.co
# The ingest function authenticates on THIS alone. On Lovable Cloud secret values
# can't be read, so set INGEST_SECRET to a value you choose (Cloud > Secrets), and
# put the same value here.
INGEST_SECRET=__set_a_value_in_lovable_cloud_secrets_and_match_it_here__

# --- gateway bearer: ONE of these (anon key is public + sufficient) ---
# Anon/publishable key passes Supabase's API gateway; service-role NOT required.
SUPABASE_ANON_KEY=__supabase_publishable_anon_key__
# Optional; only if you have it. Takes precedence over the anon key if set.
SUPABASE_SERVICE_ROLE_KEY=

# --- X / Twitter fetch (pick ONE; tried in this order if multiple set) ---
# 1. X API v2 (most reliable, paid Basic tier)
X_BEARER_TOKEN=
# 2. Apify X scraper actor (robust, paid per run). Optionally override the actor.
APIFY_TOKEN=
# X_APIFY_ACTOR=apidojo~tweet-scraper
# 3. Nitter RSS (free, flaky) — comma-separated instance base URLs
# NITTER_INSTANCES=https://nitter.net,https://nitter.poast.org

# --- optional ---
# Local bandwidth cache: skip re-POSTing already-sent URLs. OFF by default so
# the cloud's dedup response stays authoritative. Set to 1 to enable.
RAWI_SENT_CACHE=0
